# Copy to .env and edit as needed.

# Postgres
POSTGRES_DB=tickerlens
POSTGRES_USER=tickerlens
POSTGRES_PASSWORD=tickerlens
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW_DOCS=raw-docs
TICKERLENS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# Qdrant
QDRANT_PORT=6333

# OpenSearch
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe_123456789!

# API
API_PORT=8000

# OpenAI (required for Phase 5 embeddings/search)
OPENAI_API_KEY=

# Phase 8 chat (optional tuning)
TICKERLENS_OPENAI_CHAT_MODEL=gpt-4o-mini
TICKERLENS_OPENAI_CHAT_TEMPERATURE=0.2
TICKERLENS_OPENAI_CHAT_MAX_TOKENS=900

# Phase 7 reranking (optional)
TICKERLENS_OPENAI_RERANK_MODEL=gpt-4o-mini
TICKERLENS_OPENAI_RERANK_MAX_PASSAGE_CHARS=1200
TICKERLENS_RERANK_BACKEND=fastembed
TICKERLENS_FASTEMBED_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
TICKERLENS_FASTEMBED_RERANK_BATCH_SIZE=32

# Phase 10 ingestion (NSE daily scheduler)
TICKERLENS_INGESTION_ENABLED=true
TICKERLENS_INGESTION_UNIVERSE_ID=NIFTY_50
TICKERLENS_INGESTION_LOOKBACK_DAYS=3
TICKERLENS_INGESTION_LIMIT_PER_TICKER=10
TICKERLENS_INGESTION_SCHEDULER_ENABLED=true
TICKERLENS_INGESTION_CRON_HOUR_IST=19
TICKERLENS_INGESTION_CRON_MINUTE_IST=0
TICKERLENS_NSE_TIMEOUT_S=30
TICKERLENS_NSE_THROTTLE_MS=250

# Phase 11 auth + sessions
TICKERLENS_AUTH_ENABLED=true
TICKERLENS_AUTH_ALLOW_REGISTER=true
TICKERLENS_AUTH_BOOTSTRAP_ADMIN_EMAIL=
TICKERLENS_AUTH_BOOTSTRAP_ADMIN_PASSWORD=
TICKERLENS_AUTH_SESSION_COOKIE_NAME=tickerlens_session
TICKERLENS_AUTH_SESSION_TTL_HOURS=168
TICKERLENS_AUTH_COOKIE_SECURE=false
TICKERLENS_AUTH_COOKIE_SAMESITE=lax

# Phase 11 observability
TICKERLENS_METRICS_ENABLED=true
TICKERLENS_METRICS_PATH=/metrics
TICKERLENS_OTEL_ENABLED=false
TICKERLENS_OTEL_SERVICE_NAME=tickerlens-api
TICKERLENS_OTEL_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Observability UI
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
TEMPO_PORT=3200
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# Redis (rate limiting)
TICKERLENS_REDIS_URL=redis://redis:6379/0
TICKERLENS_RL_CHAT_PER_MINUTE=20
TICKERLENS_RL_VECTOR_SEARCH_PER_MINUTE=60
TICKERLENS_RL_DOC_DOWNLOAD_PER_MINUTE=120
TICKERLENS_RL_DOC_UPLOAD_PER_MINUTE=10
