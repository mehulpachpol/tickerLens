# Copy to .env and edit as needed.

# Postgres
POSTGRES_DB=tickerlens
POSTGRES_USER=tickerlens
POSTGRES_PASSWORD=tickerlens
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW_DOCS=raw-docs

# Qdrant
QDRANT_PORT=6333

# OpenSearch
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe_123456789!

# API
API_PORT=8000

# OpenAI (required for Phase 5 embeddings/search)
OPENAI_API_KEY=

# Phase 7 reranking (optional)
TICKERLENS_OPENAI_RERANK_MODEL=gpt-4o-mini
TICKERLENS_OPENAI_RERANK_MAX_PASSAGE_CHARS=1200
TICKERLENS_RERANK_BACKEND=fastembed
TICKERLENS_FASTEMBED_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
TICKERLENS_FASTEMBED_RERANK_BATCH_SIZE=32
